{
  "expo": {
    "name": "QuittungsCH",
    "slug": "quittungsch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ch.quittungsch.app",
      "infoPlist": {
        "NSCameraUsageDescription": "QuittungsCH benötigt Kamerazugriff, um Belege zu fotografieren.",
        "NSPhotoLibraryUsageDescription": "QuittungsCH benötigt Zugriff auf Fotos, um Belege auszuwählen."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "package": "ch.quittungsch.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "QuittungsCH benötigt Kamerazugriff für Belege."
        }
      ]
    ],
    "newArchEnabled": false,
    "extra": {
      "apiUrl": "http://localhost:3000"
    }
  }
}
