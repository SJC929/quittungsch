# ═══════════════════════════════════════════════════════════════════════════════
# QuittungsCH – Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=QuittungsCH

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Magic link email provider (optional – required for email magic links)
EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
EMAIL_FROM=noreply@quittungsch.ch

# ─── Database (Switzerland-hosted) ───────────────────────────────────────────
# Options:
#   Supabase (CH region via Supabase)
#   Railway (eu-central-1)
#   Infomaniak (CH)
#   Exoscale (CH-GVA-2)
DATABASE_URL=postgresql://user:password@host:5432/quittungsch

# ─── Storage (Switzerland region) ────────────────────────────────────────────
STORAGE_PROVIDER=supabase        # 'supabase' | 's3'

# Supabase Storage (Swiss data residency)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# AWS S3 eu-central-2 (Zürich) – alternative
AWS_S3_BUCKET=quittungsch-receipts
AWS_S3_REGION=eu-central-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Rate Limiting (Upstash Redis) ───────────────────────────────────────────
# Optional – if not set, rate limiting is disabled (dev mode)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── AI / OCR ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# OCR Provider Selection
OCR_PRIMARY_PROVIDER=google_vision   # 'google_vision' | 'aws_textract'
OCR_FALLBACK_ENABLED=true
OCR_OFFLINE_FALLBACK=tesseract       # 'tesseract' | 'none'

# Google Cloud Vision API
GOOGLE_VISION_API_KEY=

# AWS Textract (scaffold – not implemented)
AWS_TEXTRACT_REGION=eu-central-1

# ─── Payments ─────────────────────────────────────────────────────────────────
# BOTH providers are DISABLED by default.
# The app runs in free-trial mode until you enable one.
# Only enable ONE provider at a time.

PAYMENT_STRIPE_ENABLED=false
PAYMENT_TWINT_VIA_STRIPE=false       # Enable TWINT via Stripe (requires Stripe)
PAYMENT_DATATRANS_ENABLED=false

# ── Stripe (fill when ready to go live) ──────────────────────────────────────
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create a recurring price in Stripe Dashboard (CHF 10/month)
STRIPE_PRICE_ID_MONTHLY=price_...

# ── Datatrans / TWINT (fill when ready) ──────────────────────────────────────
# Get credentials from: https://admin.datatrans.com
DATATRANS_MERCHANT_ID=
DATATRANS_API_KEY=
DATATRANS_WEBHOOK_SECRET=

# ─── Mobile App ───────────────────────────────────────────────────────────────
# Set in apps/mobile/app.json → expo.extra.apiUrl
# EXPO_PUBLIC_API_URL=https://your-production-url.com
