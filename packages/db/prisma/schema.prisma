// QuittungsCH – Prisma Schema
// Swiss-hosted PostgreSQL (Supabase / Railway CH / Infomaniak)

generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum Plan {
  FREE
  TRIAL
  PRO
}

enum PaymentProvider {
  STRIPE
  DATATRANS
  NONE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}

enum OcrProvider {
  GOOGLE_VISION
  AWS_TEXTRACT
  CLAUDE
  TESSERACT
  QR
  MANUAL
}

enum ReceiptType {
  KASSENBON
  RECHNUNG
  TANKBELEG
  QR_RECHNUNG
  SONSTIGE
}

enum PaymentMethod {
  CASH
  CARD
  TWINT
  BANK_TRANSFER
  UNKNOWN
}

enum ExportFormat {
  EXCEL
  CSV
  PDF
  GOOGLE_SHEETS
}

enum ExpenseCategory {
  RESTAURANT
  TANKSTELLE
  BUERO
  TELEFON
  TRANSPORT
  UNTERKUNFT
  VERSICHERUNG
  WEITERBILDUNG
  DIVERSES
}

// ─── Tenant ──────────────────────────────────────────────────────────────────

model Tenant {
  id                 String          @id @default(cuid())
  name               String
  slug               String          @unique
  uid                String?         // MwSt-Nummer (optional)
  plan               Plan            @default(TRIAL)
  trialEndsAt        DateTime?
  activeProvider     PaymentProvider @default(NONE)
  stripeCustomerId   String?         @unique
  datatransCustomerId String?        @unique
  ocrEnabled         Boolean         @default(true)
  preferredLanguage  String          @default("de")
  preferredExportFormat ExportFormat @default(EXCEL)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  users         User[]
  expenses      Expense[]
  categories    Category[]
  subscriptions Subscription[]
  exports       Export[]
  kilometerLogs KilometerLog[]
  auditLogs     AuditLog[]

  @@index([slug])
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  hashedPassword String?
  role           Role     @default(MEMBER)
  tenantId       String
  emailVerified  DateTime?
  image          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  expenses      Expense[]
  kilometerLogs KilometerLog[]
  exports       Export[]
  sessions      Session[]
  accounts      Account[]
  auditLogs     AuditLog[]

  @@index([tenantId])
  @@index([email])
}

// ─── NextAuth models ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Subscription ─────────────────────────────────────────────────────────────

model Subscription {
  id                     String             @id @default(cuid())
  tenantId               String
  provider               PaymentProvider
  externalSubscriptionId String?            @unique
  externalCustomerId     String?
  status                 SubscriptionStatus @default(TRIALING)
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([externalSubscriptionId])
}

// ─── Expense ──────────────────────────────────────────────────────────────────

model Expense {
  id               String          @id @default(cuid())
  tenantId         String
  userId           String
  amount           Float
  currency         String          @default("CHF")
  merchantName     String?
  date             DateTime
  category         ExpenseCategory @default(DIVERSES)
  vatAmount        Float?
  vatRate          Float?          // 8.1 | 3.8 | 2.5 | 0
  subtotal         Float?
  receiptType      ReceiptType     @default(KASSENBON)
  paymentMethod    PaymentMethod   @default(UNKNOWN)
  lineItems        Json?           // [{ description: string, amount: number }]
  notes            String?
  receiptImageUrl  String?
  receiptFileName  String?
  ocrRawText       String?
  ocrConfidence    Float?
  ocrProvider      OcrProvider?
  needsReview      Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id])
  auditLogs AuditLog[]

  @@index([tenantId])
  @@index([tenantId, date])
  @@index([tenantId, category])
  @@index([needsReview])
}

// ─── Category ─────────────────────────────────────────────────────────────────

model Category {
  id       String  @id @default(cuid())
  tenantId String
  name     String
  color    String  @default("#6B7280")
  icon     String  @default("tag")
  isDefault Boolean @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ─── KilometerLog (Phase 2 – scaffolded) ─────────────────────────────────────

model KilometerLog {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String
  date         DateTime
  fromLocation String
  toLocation   String
  distanceKm   Float
  purpose      String?
  ratePerKm    Float    @default(0.70) // CHF 0.70 Swiss tax standard
  totalAmount  Float?   // computed: distanceKm * ratePerKm
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([tenantId, date])
}

// ─── Export ───────────────────────────────────────────────────────────────────

model Export {
  id        String       @id @default(cuid())
  tenantId  String
  userId    String
  format    ExportFormat
  dateFrom  DateTime
  dateTo    DateTime
  fileUrl   String?
  fileName  String?
  status    String       @default("pending") // pending | processing | done | error
  createdAt DateTime     @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
}

// ─── AuditLog ─────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  entityType String   // 'expense' | 'subscription' | 'tenant'
  entityId   String
  action     String   // 'create' | 'update' | 'delete'
  changes    Json?    // { field: { before, after } }
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id])
  expense Expense? @relation(fields: [entityId], references: [id])

  @@index([tenantId])
  @@index([entityId])
}
